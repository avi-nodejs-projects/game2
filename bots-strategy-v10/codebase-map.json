    "modify_logging": {
      "description": "Change log output format or add event types",
      "files": ["js/config.js:simulationSettings", "js/log.js"]
    },
    "change_ui_layout": {
      "description": "Modify setup UI structure or add tabs",
      "files": ["index.html", "styles.css", "js/ui.js"]
    },
    "add_settings_section": {
      "description": "Add new configurable settings group",
